# Supabase — copy to `.env.local` and fill with values from your Supabase project (Settings → API).
# Never commit real secrets or the service role key to git.

# ── Promax Event Platform ──────────────────────────────────────────
EVENT_SLUG=yoruba-day-canberra-2026

# ── Supabase (database + auth) ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── SMTP (email via Nodemailer) ────────────────────────────────────
# Required for RSVP and sponsor confirmation emails.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME="Yoruba Day Canberra 2026"

# ── Site URL (SEO, calendar links) ───────────────────────────────────
# NEXT_PUBLIC_SITE_URL=https://yorubadaycanberra.org

# ── Optional: health check insert test in production ─────────────────
# ENABLE_RSVP_INSERT_TEST=false
