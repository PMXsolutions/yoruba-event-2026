# Supabase — copy to `.env.local` and fill with values from your Supabase project (Settings → API).
# Never commit real secrets or the service role key to git.

# Project URL (public)
NEXT_PUBLIC_SUPABASE_URL=

# Anon (public) key — safe to expose in the browser; used by `lib/supabase/client.ts` for future features.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server only. Used by Server Actions to insert RSVPs. Do not expose to the client.
SUPABASE_SERVICE_ROLE_KEY=
