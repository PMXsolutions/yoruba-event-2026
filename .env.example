# Supabase — copy to `.env.local` and fill with values from your Supabase project (Settings → API).
# Never commit real secrets or the service role key to git.

# ── Promax Event Platform ──────────────────────────────────────────
# Active event configuration (defaults to yoruba-day-canberra-2026)
EVENT_SLUG=yoruba-day-canberra-2026

# ── Supabase (database) ────────────────────────────────────────────
# Project URL (public) — use https://<ref>.supabase.co only (no /rest/v1)
NEXT_PUBLIC_SUPABASE_URL=

# Anon (public) key — browser client for future authenticated features
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server only. RSVP Engine inserts. Do not expose to client.
SUPABASE_SERVICE_ROLE_KEY=

# ── Resend (email) — optional, activates confirmation emails ───────
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── Twilio (SMS) — future, not active in v1 ────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# NOTIFY_SMS_ENABLED=false

# ── AI — future, not active in v1 ──────────────────────────────────
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# AI_ENABLED=false
